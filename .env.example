# Required: initialized llm-wiki workspace. Markdown output is written to raw/untracked.
WIKI_WORKSPACE_PATH=/absolute/path/to/wiki-workspace

# Required in production: bearer token expected by the MCP server.
# Generate one with:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=

# Optional service settings.
DOCUMENTS_MCP_PORT=3337
DOCUMENT_INPUT_HOST_DIR=./documents/input
DOCUMENT_MAX_UPLOAD_BYTES=52428800
DOCUMENT_ENABLE_OCR=true
DOCUMENT_OCR_LANG=eng+fra
